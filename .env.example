# Backend Environment Variables (.env.example)
# Copy this file to .env.local and fill in your actual values

# ─── MySQL Database Configuration ────────────────────────────
MYSQL_URL=jdbc:mysql://localhost:3306/petcare_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

# ─── JWT Secret Configuration ────────────────────────────────
JWT_SECRET=PetCareConnectSuperSecretKeyFor256BitHMACAlgorithm!!
JWT_EXPIRATION=86400000

# ─── API Keys (Get these from their respective services) ─────
# Gemini API Key: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# Groq API Key: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Google Gemini Vision Model: https://ai.google.dev/
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key-here

# ─── Server Configuration ────────────────────────────────────
SERVER_PORT=8080
